# ============================================================
# E-Quran Academy — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit the actual .env.local file.
# ============================================================

# ==================== API ====================
# During development the Vite proxy forwards /api/* to the backend.
# In production set this to your deployed API origin.
VITE_API_BASE_URL=http://localhost:5000

# ==================== GOOGLE (optional) ====================
# Required only if you use Gemini AI features in the frontend
GEMINI_API_KEY=your_gemini_api_key_here
