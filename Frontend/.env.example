# ============================================================
# E-Quran Academy Frontend — Environment Template
# Copy to Frontend/.env to override defaults.
# ============================================================

# Base URL for API calls.
# Leave empty to use the relative `/api` path (the Vite dev server
# proxies `/api` -> http://localhost:5000 by default).
VITE_API_BASE_URL=

# Direct backend origin. Used for Google OAuth redirects, which must
# bypass the Vite proxy and hit the backend directly.
VITE_BACKEND_URL=http://localhost:5000
