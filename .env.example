# ============================================================
# E-Quran Academy — Root Environment Template
# Copy this file to `.env` (or use the dedicated Backend/.env and
# Frontend/.env files) and fill in the values for local development.
# ============================================================

# ----- Backend (server) -----
NODE_ENV=development
PORT=5000

# Public URL of the frontend (used for CORS + OAuth redirects)
FRONTEND_URL=http://localhost:3000

# MySQL (XAMPP defaults shown — change for production)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=equran_academy

# JWT secrets — REQUIRED in production. Use long random strings.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer / SendGrid)
EMAIL_FROM="E-Quran Academy <no-reply@equran.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Optional: use SendGrid instead of SMTP
SENDGRID_API_KEY=

# Google OAuth (leave blank to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (leave blank to disable payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Frontend (Vite) -----
# Base URL for API calls. Defaults to a relative `/api` (proxied by Vite)
# in development. Set this only if the API is on a separate origin.
VITE_API_BASE_URL=
# Direct backend origin used by Google OAuth redirects (must be the
# real backend host, not the Vite dev server).
VITE_BACKEND_URL=http://localhost:5000
