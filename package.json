{
  "name": "equran-academy",
  "private": true,
  "version": "1.0.0",
  "description": "E-Quran Academy LMS — multi-role learning platform (React + Express + MySQL)",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:backend:dev\" \"npm:frontend:dev\"",
    "frontend:dev": "npm --prefix Frontend run dev",
    "frontend:build": "npm --prefix Frontend run build",
    "frontend:lint": "npm --prefix Frontend run lint",
    "backend:dev": "npm --prefix Backend run dev",
    "backend:start": "npm --prefix Backend run start",
    "install:all": "npm install && npm --prefix Backend install && npm --prefix Frontend install",
    "build": "npm run frontend:build"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
