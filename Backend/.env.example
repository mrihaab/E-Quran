# ============================================================
# E-Quran Academy Backend — Environment Template
# Copy to Backend/.env and fill in the values.
# ============================================================

NODE_ENV=development
PORT=5000

# Public URL of the frontend (used for CORS + OAuth redirects)
FRONTEND_URL=http://localhost:3000

# ----- MySQL (XAMPP defaults shown) -----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=equran_academy

# ----- JWT -----
# REQUIRED in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----- Email (Nodemailer / SendGrid) -----
EMAIL_FROM="E-Quran Academy <no-reply@equran.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=

# ----- Google OAuth (optional) -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Stripe (optional) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
