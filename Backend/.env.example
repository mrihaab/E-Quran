# ============================================
# E-Quran Academy Backend Configuration
# Copy this file to .env and fill in your values
# ============================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=equran_academy
DB_PORT=3306
DB_CONNECTION_LIMIT=10

# JWT (REQUIRED - generate strong random secrets)
JWT_SECRET=your-strong-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=your-strong-random-refresh-secret-at-least-32-characters

# Session (used for OAuth state management)
SESSION_SECRET=your-session-secret-here

# Email (SMTP - Gmail App Password or SendGrid)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
ADMIN_EMAIL=admin@equran.com

# Predefined Admin Emails (comma-separated, auto-approved on registration)
ADMIN_EMAILS=admin@equran.com

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
